{
  "name": "arm-livewatch",
  "displayName": "ARM LiveWatch",
  "description": "Real-time variable watch for ARM Cortex-M microcontrollers via OpenOCD, like Keil's Live Watch",
  "version": "0.1.3",
  "publisher": "Misaka21",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/misaka21/ARM_livewatch"
  },
  "keywords": [
    "arm",
    "cortex-m",
    "stm32",
    "openocd",
    "embedded",
    "live watch",
    "debug",
    "mcu",
    "gdb"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Debuggers"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "livewatch-sidebar",
          "title": "ARM LiveWatch",
          "icon": "$(eye)"
        }
      ]
    },
    "views": {
      "livewatch-sidebar": [
        {
          "type": "webview",
          "id": "livewatch.watchView",
          "name": "ARM LiveWatch"
        }
      ]
    },
    "commands": [
      {
        "command": "livewatch.addWatch",
        "title": "Add Watch Variable",
        "icon": "$(add)",
        "category": "ARM LiveWatch"
      },
      {
        "command": "livewatch.removeWatch",
        "title": "Remove Watch Variable",
        "icon": "$(trash)",
        "category": "ARM LiveWatch"
      },
      {
        "command": "livewatch.pausePolling",
        "title": "Pause Polling",
        "icon": "$(debug-pause)",
        "category": "ARM LiveWatch"
      },
      {
        "command": "livewatch.resumePolling",
        "title": "Resume Polling",
        "icon": "$(debug-start)",
        "category": "ARM LiveWatch"
      },
      {
        "command": "livewatch.clearAll",
        "title": "Clear All Watches",
        "icon": "$(clear-all)",
        "category": "ARM LiveWatch"
      },
      {
        "command": "livewatch.refreshSymbols",
        "title": "Re-resolve All Symbols",
        "icon": "$(refresh)",
        "category": "ARM LiveWatch"
      }
    ],
    "configuration": {
      "title": "ARM LiveWatch",
      "properties": {
        "livewatch.elfPath": {
          "type": "string",
          "default": "",
          "description": "Path to ELF file with debug symbols. Leave empty for auto-detect."
        },
        "livewatch.gdbPath": {
          "type": "string",
          "default": "arm-none-eabi-gdb",
          "description": "Path to arm-none-eabi-gdb executable"
        },
        "livewatch.svdPath": {
          "type": "string",
          "default": "",
          "description": "Path to SVD file for peripheral register names (optional)"
        },
        "livewatch.openocdHost": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "OpenOCD TCL server host"
        },
        "livewatch.openocdPort": {
          "type": "number",
          "default": 6666,
          "description": "OpenOCD TCL server port"
        },
        "livewatch.ramRegions": {
          "type": "array",
          "default": [
            "0x20000000-0x40000000",
            "0x10000000-0x20000000"
          ],
          "description": "RAM address ranges used for pointer validation. Format each entry as 0xSTART-0xEND.",
          "items": {
            "type": "string"
          }
        },
        "livewatch.pollInterval": {
          "type": "number",
          "default": 200,
          "description": "Polling interval in milliseconds",
          "minimum": 50,
          "maximum": 5000
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
